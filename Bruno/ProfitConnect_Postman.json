{
  "info": {
    "name": "ProfitConnect API",
    "_postman_id": "a1b2c3d4-1234-5678-9101-profitconnect",
    "description": "مجموعة شاملة لجميع واجهات API لمشروع ProfitConnect. تحتوي على 43 endpoint موزعة على 9 مجموعات.\n\n## كيفية الاستخدام:\n1. استورد الملف في Postman\n2. استورد ملف البيئة (Environment) المرفق\n3. اختر environment \"ProfitConnect Local\"\n4. سخّل الدخول أولاً عبر Auth > Login ليتم تعيين التوكن تلقائياً\n5. ابدأ باختبار باقي الـ endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Auth",
      "description": "مصادقة المستخدمين - تسجيل، دخول، جلب المستخدم الحالي",
      "item": [
        {
          "name": "Signup - إنشاء حساب",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.environment.set('authToken', response.token);",
                  "    pm.environment.set('userId', response.user.id);",
                  "    pm.environment.set('userEmail', response.user.email);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "firstName", "value": "{{firstName}}", "type": "text" },
                { "key": "lastName", "value": "{{lastName}}", "type": "text" },
                { "key": "email", "value": "{{email}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" },
                { "key": "role", "value": "{{role}}", "type": "text" },
                { "key": "phoneNumber", "value": "{{phoneNumber}}", "type": "text" },
                { "key": "industry", "value": "{{industry}}", "type": "text" },
                { "key": "yearsOfExperience", "value": "{{yearsOfExperience}}", "type": "text" },
                { "key": "skills", "value": "{{skills}}", "type": "text" },
                { "key": "avatar", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "إنشاء حساب مستخدم جديد. يرسل البيانات كـ multipart/form-data لدعم رفع الصورة."
          },
          "response": [
            {
              "name": "Success",
              "status": "Created",
              "code": 201,
              "header": [],
              "body": "{\n  \"success\": true,\n  \"token\": \"eyJhbG...\",\n  \"user\": {\n    \"id\": \"667a...\",\n    \"email\": \"user@example.com\",\n    \"username\": \"ahmed_1234567890\",\n    \"role\": \"Student\",\n    \"profile\": { \"firstName\": \"أحمد\", \"lastName\": \"علي\", ... }\n  }\n}"
